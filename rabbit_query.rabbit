// Simple XPath query example for Rabbit language
// This demonstrates querying HTML nodes

let $security_rules := ('Deny ICMP', 'Block R&D egress', 'Isolate Guest VLAN')

for $rule in $security_rules
return concat('Firewall Rule: ', $rule)

// Outputs:
// Firewall Rule: Deny ICMP
// Firewall Rule: Block R&D egress  
// Firewall Rule: Isolate Guest VLAN